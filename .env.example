# Learning-hub API
HUB_URL=http://localhost:3000

# Gemini API (optional — used by fake hub server for real LLM answers)
# Get your key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# STT engine: whisper | console
STT_ENGINE=whisper
WHISPER_MODEL=base
# WHISPER_DEVICE=auto
# WHISPER_LANGUAGE=en

# TTS engine: piper | kokoro | console
TTS_ENGINE=console
# PIPER_MODEL_PATH=/path/to/model.onnx
# KOKORO_VOICE=af_heart
# KOKORO_LANG_CODE=a
# KOKORO_SPEED=1.0

# Audio devices (integer index, leave blank for system default)
# Run: python -c "import pyaudio; p=pyaudio.PyAudio(); [print(i, p.get_device_info_by_index(i)['name']) for i in range(p.get_device_count())]"
# AUDIO_INPUT_DEVICE=
# AUDIO_OUTPUT_DEVICE=

# VAD tuning
# VAD_THRESHOLD=0.02
# VAD_SILENCE_DURATION=1.5
# VAD_MIN_SPEECH_DURATION=0.3

# Hugging Face Hub offline mode (set to 1 to prevent any online access or checking for newer models)
# HF_HUB_OFFLINE=1

LOG_LEVEL=INFO
